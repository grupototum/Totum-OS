# 🔑 Configurações de Ambiente - Totum Dev
# Status: PRONTO PARA PRODUÇÃO REAL

# ============================================================
# MODO DE EXECUÇÃO
# ============================================================
# false = Usar Ollama REAL para processamento (produção)
# true = Usar mock mode com fallback determinístico
MOCK_MODE=false

# ============================================================
# OLLAMA (Local AI - Produção Real)
# ============================================================
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat  # Modelos alternativos: llama2, mistral, orca-mini

# ============================================================
# SUPABASE (RAG Database)
# ============================================================
SUPABASE_URL=https://cgpkfhrqprqptvehatad.supabase.co
SUPABASE_KEY=your_api_key_here_optional

# ============================================================
# LOGGING
# ============================================================
# debug, info, warn, error
LOG_LEVEL=info

# ============================================================
# PERFORMANCE
# ============================================================
BATCH_SIZE=5
TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=3
