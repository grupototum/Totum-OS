# ============================================================
# TOTUM — Variáveis de Ambiente (Frontend Vite)
# ============================================================
# COMO USAR:
#   cp .env.example .env
#   Preencha cada valor e NUNCA commite o .env com dados reais.
#
# DEPLOY (Vercel):
#   Todas as vars VITE_* devem ser adicionadas em:
#   Vercel → Project Settings → Environment Variables
#
# IMPORTANTE: Variáveis VITE_* são expostas no bundle do frontend.
#   Coloque aqui APENAS keys que podem ser públicas (anon keys, client IDs).
#   Keys server-side secretas devem ficar em Edge Functions / backend.
# ============================================================

# ============================================================
# SUPABASE — OBRIGATÓRIO (app inteira depende disso)
# Obter em: https://supabase.com/dashboard/project/_/settings/api
# ============================================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# OPENCLAW VPS — Agentes reais vs Mock
# Sem VITE_OPENCLAW_URL o app entra em MOCK_MODE (dados simulados)
# ============================================================
VITE_OPENCLAW_URL=https://seu-tunnel.cloudflare.com
VITE_OPENCLAW_MOCK=false
# Token de autenticação do gateway — OBRIGATÓRIO para agentes reais
# Gerar via OpenClaw admin. NUNCA deixar vazio em produção.
VITE_OPENCLAW_TOKEN=seu_token_openclaw_aqui

# ============================================================
# AI PROVIDERS — Pelo menos um obrigatório para chat funcionar
# ============================================================

# Gemini (desbloqueia: Hermione, Ada Diagrams, Embeddings semânticos)
# Obter em: https://aistudio.google.com/app/apikey (free tier disponível)
VITE_GEMINI_API_KEY=sua_gemini_api_key_aqui

# Groq (desbloqueia: chat de agentes principal, fallback do docs chat)
# Obter em: https://console.groq.com/keys (free tier generoso)
VITE_GROQ_API_KEY=sua_groq_api_key_aqui

# Kimi / Moonshot AI (provider alternativo para agentes)
# Obter em: https://platform.moonshot.cn/
VITE_KIMI_API_KEY=sua_kimi_api_key_aqui

# OpenAI (provider alternativo para agentes)
# Obter em: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sua_openai_api_key_aqui

# ============================================================
# OLLAMA — Chat local / Cráudio Codete / Transcrição
# Aponte para a VPS onde o Ollama está rodando
# Em desenvolvimento local: http://localhost:11434
# ============================================================
VITE_OLLAMA_URL=http://187.127.4.140:11434

# ============================================================
# TELEGRAM — Notificações de tarefas e agentes
# Criar bot via @BotFather no Telegram
# ============================================================
VITE_TELEGRAM_BOT_TOKEN=seu_bot_token_aqui

# ============================================================
# SUNA — Agente autônomo
# Configurar se instância Suna estiver instalada na VPS
# ============================================================
VITE_SUNA_URL=https://sua-instancia-suna.com
VITE_SUNA_API_KEY=sua_suna_api_key_aqui

# ============================================================
# GOOGLE DRIVE — Embed de arquivos
# Criar OAuth Client ID em: https://console.cloud.google.com/
# Tipo: Web application, com origin do domínio do app
# ============================================================
VITE_GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com

# ============================================================
# HOSTING PANEL — Monitoramento de VPS
# ============================================================
VITE_BESZEL_URL=https://seu-beszel.dominio.com
VITE_UPTIME_KUMA_URL=https://seu-uptime-kuma.dominio.com

# ============================================================
# OUTROS
# ============================================================
# Senha de acesso à página de Plano de Ação (opcional)
VITE_ACTION_PLAN_PASSWORD=sua_senha_aqui

# URL do backend REST API (se usado)
VITE_API_URL=http://localhost:3000/api

# n8n workflow automation embed (opcional)
# VITE_N8N_URL=https://seu-n8n.dominio.com

# ============================================================
# LOGGING (não precisam do prefixo VITE_ — server-side only)
# ============================================================
LOG_LEVEL=info
BATCH_SIZE=5
TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=3
