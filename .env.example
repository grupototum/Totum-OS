# 🔑 Configurações de Ambiente - Frontend
# ⚠️ NUNCA commitar secrets reais neste arquivo!
# Variáveis com prefixo VITE_ são expostas ao frontend (seguro = públicas)

# ============================================================
# SUPABASE (Frontend - Público)
# Obter em: https://supabase.com/dashboard/project/_/settings/api
# ============================================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui

# ============================================================
# OpenClaw VPS Configuration
# ============================================================
VITE_OPENCLAW_URL=http://seu-vps:3002
VITE_OPENCLAW_MOCK=false

# ============================================================
# API Configuration
# ============================================================
VITE_API_URL=http://localhost:3000/api

# ============================================================
# Integrações de IA (Opcional)
# ============================================================
VITE_KIMI_API_KEY=opcional
VITE_GROQ_API_KEY=opcional
VITE_OPENAI_API_KEY=opcional

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
BATCH_SIZE=5
TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=3
