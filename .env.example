# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Action Plan Password (for protecting the implantation dashboard)
# Set this to enable password protection on the Action Plan page
VITE_ACTION_PLAN_PASSWORD=your-secure-password-here

# Kimi/Groq API Configuration for AI Chat
# Get your API key from: https://platform.moonshot.cn/ (Kimi) or https://console.groq.com/ (Groq)
VITE_KIMI_API_KEY=your-kimi-api-key-here
VITE_GROQ_API_KEY=your-groq-api-key-here

# Optional: Default AI Provider (kimi | groq | openai)
VITE_DEFAULT_AI_PROVIDER=kimi
