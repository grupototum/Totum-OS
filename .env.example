# 🔑 Configurações de Ambiente - Frontend
# Variáveis com prefixo VITE_ são expostas ao frontend

# ============================================================
# SUPABASE (Frontend) - Obrigatório
# ============================================================
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui

# ============================================================
# SUPABASE (Backend API) - Obrigatório
# ============================================================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_anon_key_aqui

# ⚠️ SERVICE ROLE KEY - NUNCA expor no frontend!
# Obter em: https://supabase.com/dashboard/project/_/settings/api
# Esta chave ignora RLS - usar APENAS em API routes server-side
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ============================================================
# MODO DE EXECUÇÃO
# ============================================================
MOCK_MODE=false

# ============================================================
# OLLAMA (Local AI / VPS) - Opcional
# Use VITE_ prefix para que o frontend possa acessar
# Configure também no Settings → Sistema para persistir no navegador
# ============================================================
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2:3b

# ============================================================
# CODEFLOW (ADA / Análise de funções VPS) - Opcional
# Server-side only — não precisa de VITE_ prefix
# ============================================================
CODEFLOW_URL=http://localhost:8002

# ============================================================
# N8N (Workflows) - Opcional
# ============================================================
VITE_N8N_URL=http://localhost:5678
VITE_N8N_API_KEY=sua_n8n_api_key_aqui

# ============================================================
# GROQ (Tier 2) - Opcional
# ============================================================
GROQ_API_KEY=sua_groq_key_aqui

# ============================================================
# ANTHROPIC (Tier 1) - Opcional
# ============================================================
ANTHROPIC_API_KEY=sua_anthropic_key_aqui

# ============================================================
# TELEGRAM BOTS - Opcional
# ============================================================
# TELEGRAM_BOT_TOKEN_DEFAULT=seu_token_aqui

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
BATCH_SIZE=5
TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=3
